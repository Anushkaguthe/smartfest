<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Fest Pass</title>
    <!-- Bootstrap CDN for quick styling -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f5f5;
        }
        .hero {
            background: linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)), url('/images/fest_image.jpeg') no-repeat center center;
            background-size: cover;
            height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
        }
       

        .hero h1 {
            font-size: 3rem;
        }
        .btn-container {
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Smart Fest Pass</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero text-center">
        <div>
            <h1>Welcome to Smart Fest!</h1>
            <p class="lead">The ultimate fest experience — competitions, workshops, food, and fun!</p>
            <div class="btn-container">
                <a href="/login" class="btn btn-primary btn-lg me-2">Login</a>
                <a href="/register" class="btn btn-success btn-lg">Register</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="container my-5">
        <h2 class="text-center mb-4">About Smart Fest</h2>
        <p class="text-center">
            Smart Fest is a celebration of creativity, technology, and culture! Join workshops, participate in events, and showcase your talent.
            Whether you're a student, a tech enthusiast, or just looking for fun, Smart Fest has something for everyone.
        </p>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-3">
        &copy; 2025 Smart Fest. All Rights Reserved.
    </footer>

    <!-- Bootstrap JS (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
