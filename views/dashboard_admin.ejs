<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card {
            margin-bottom: 30px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        h1, h2 {
            color: #333;
        }
        table th {
            background-color: #0d6efd;
            color: white;
        }
        table tr:hover {
            background-color: #f1f3f6;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="#">Smart Fest Pass</a>
        <div class="d-flex">
            <span class="navbar-text me-3">Hello, <%= username %>!</span>
            <a href="/logout" class="btn btn-outline-light">Logout</a>
        </div>
    </div>
</nav>
    <div class="container mt-5">
        <h1 class="mb-4 text-center">Welcome, Admin <%= username %>!</h1>

        <!-- Participants Card -->
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Registered Participants</h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Age</th>
                                <th>Contact</th>
                                <th>Username</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (participants && participants.length > 0) { %>
                                <% participants.forEach(p => { %>
                                    <tr>
                                        <td><%= p.id %></td>
                                        <td><%= p.student_name %></td>
                                        <td><%= p.age %></td>
                                        <td><%= p.contact %></td>
                                        <td><%= p.username %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="text-center">No participants found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Events Card -->
        <div class="card">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0">Events List</h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Event ID</th>
                                <th>Name</th>
                                <th>Venue</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (events && events.length > 0) { %>
                                <% events.forEach(e => { %>
                                    <tr>
                                        <td><%= e.event_id %></td>
                                        <td><%= e.event_name %></td>
                                        <td><%= e.venue %></td>
                                        <td><%= e.event_date.toISOString().slice(0,10) %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="4" class="text-center">No events found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
