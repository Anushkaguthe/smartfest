<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Smart Fest Pass</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background: #f5f7fa;
            margin: 0;
            padding: 0;
        }
        header {
            background: #4CAF50;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .container {
            max-width: 900px;
            margin: 30px auto;
            padding: 20px;
        }
        h2 {
            color: #333;
            margin-bottom: 5px;
        }
        p {
            color: #555;
            margin-top: 0;
        }
        .card-container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 30px;
        }
        .card {
            background: #fff;
            flex: 1 1 250px;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            text-align: center;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }
        .card h3 {
            margin-top: 0;
            color: #4CAF50;
        }
        .card button {
            margin-top: 15px;
            padding: 10px 15px;
            border: none;
            background: #4CAF50;
            color: white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }
        .card button:hover {
            background: #45a049;
        }
        .logout {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 15px;
            background: #f44336;
            color: white;
            border-radius: 6px;
            text-decoration: none;
        }
        .logout:hover {
            background: #e53935;
        }
    </style>
</head>
<body>
    <header>
        <h1>Smart Fest Pass Dashboard</h1>
    </header>

    <div class="container">
        <h2>Welcome, <%= username %>!</h2>
        <% if (typeof role !== 'undefined') { %>
            <p>Your role: <%= role %></p>
        <% } %>

        <div class="card-container">
            <div class="card">
                <h3>View Tokens</h3>
                <p>Check your event and food tokens.</p>
                <button>View</button>
            </div>
            <div class="card">
                <h3>Scan QR</h3>
                <p>Scan QR codes for event access.</p>
                <button>Scan</button>
            </div>
            <div class="card">
                <h3>Announcements</h3>
                <p>Read the latest updates for the fest.</p>
                <button>View</button>
            </div>
            <div class="card">
                <h3>Certificates</h3>
                <p>Download your participation/winner certificates.</p>
                <button>View</button>
            </div>
        </div>

        <a href="/logout" class="logout">Logout</a>
    </div>
</body>
</html>

