<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Your QR Code</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5 text-center">
    <h2>Your QR Code</h2>
    <img src="<%= qr_url %>" alt="QR Code" class="img-fluid my-3" style="max-width: 250px;">
    <p class="text-muted">Show this QR at the event counter</p>
    <a href="/dashboard/participant" class="btn btn-primary mt-3">Back to Dashboard</a>
</div>
</body>
</html>
