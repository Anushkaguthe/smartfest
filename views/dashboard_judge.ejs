<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Judge Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .event-card {
            margin-bottom: 2rem;
        }
        .event-title {
            background-color: #343a40;
            color: white;
            padding: 0.75rem 1rem;
            border-radius: 0.25rem 0.25rem 0 0;
        }
        .grade-btn {
            margin-top: 0.5rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="#">Smart Fest Pass</a>
        <div class="d-flex">
            <span class="navbar-text me-3">Hello, <%= username %>!</span>
            <a href="/logout" class="btn btn-outline-light">Logout</a>
        </div>
    </div>
</nav>
<div class="container mt-5">
    <h2 class="mb-4">Welcome, <%= username %></h2>

    <% if (eventParticipants.length === 0) { %>
        <div class="alert alert-info">No events assigned to you yet.</div>
    <% } else { %>
        <% eventParticipants.forEach(event => { %>
            <div class="card event-card shadow-sm">
                <div class="event-title">
                    <h5><%= event.event_name %> - <%= event.venue %></h5>
                </div>
                <div class="card-body">
                    <% if (event.participants.length === 0) { %>
                        <p>No participants registered for this event yet.</p>
                    <% } else { %>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Age</th>
                                    <th>Contact</th>
                                    <th>College</th>
                                    <th>Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% event.participants.forEach((p, index) => { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td><%= p.student_name %></td>
                                        <td><%= p.age %></td>
                                        <td><%= p.contact %></td>
                                        <td><%= p.college_name || 'N/A' %></td>
                                        <td>
                                            <form action="/judge/grade/<%= p.student_id %>/<%= event.event_id %>" method="POST" class="d-flex">
                                                <input type="number" name="grade" class="form-control me-2" min="0" max="100" required>
                                                <button class="btn btn-success grade-btn">Submit</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>
</body>
</html>
