<!DOCTYPE html>
<html>
<head>
  <title>QR Verification</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-5 bg-light">
  <% if (valid) { %>
    <div class="container text-center bg-white shadow p-4 rounded">
      <h2>✅ QR Verified</h2>
      <hr>
      <h4><%= participant.student_name %></h4>
      <p>Age: <%= participant.age %></p>
      <p>College ID: <%= participant.college_id %></p>
      <p>Contact: <%= participant.contact %></p>

      <h5 class="mt-4">Registered Events:</h5>
      <ul class="list-group">
        <% events.forEach(e => { %>
          <li class="list-group-item"><%= e.event_name %></li>
        <% }) %>
      </ul>
    </div>
  <% } else { %>
    <div class="text-center text-danger mt-5">
      <h3>❌ Invalid QR Code</h3>
    </div>
  <% } %>
</body>
</html>
